# LINE Messaging API Settings
# Found in LINE Developers Console -> Basic Settings & Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# Node.js webhook / scripts（與上方相同的正式金鑰，避免混用測試用變數）
# 若有需要區分，可在本機 .env 中自行覆寫，但程式碼預設使用 LINE_CHANNEL_ACCESS_TOKEN / LINE_CHANNEL_SECRET。

# OpenAI API Settings
# Found in OpenAI Platform -> API Keys & Assistants
OPENAI_API_KEY=your_key_here
OPENAI_ASSISTANT_ID=your_ID_here

# Google Gemini API (TCM: Flash / Speaking: Pro)
GEMINI_API_KEY=your_gemini_key_here

# Upstash Redis (for state, question log, quiz)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# 本機 Redis（Node.js lib/redisClient.js 使用，ioredis 單例）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# MongoDB（後端 / Node / Python 用於永久儲存對話 Log）
MONGO_URL=mongodb://localhost:27017/line_tcm_bot

# Weekly report (Cron) — 請輸入你的信箱
REPORT_EMAIL=your_email@example.com
CRON_SECRET=your_cron_secret_here

# SMTP for sending weekly PDF report
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_app_password

# Cloudinary (TTS 語音檔雲端儲存)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
